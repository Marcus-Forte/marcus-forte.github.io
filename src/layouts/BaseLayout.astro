---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const { title = "Marcus Forte", description = "Marcus Forte - personal site" } =
  Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <header>
      <nav>
        <span class="site-title">Marcus Forte</span>
        <ul>
          <li><a href="/#about">About</a></li>
          <li><a href="/#projects">Projects</a></li>
          <li><a href="/#contact">Contact</a></li>
        </ul>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <p>&copy; {new Date().getFullYear()} Marcus Forte</p>
    </footer>
  </body>
</html>
