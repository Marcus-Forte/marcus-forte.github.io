---
import "../styles/global.css";
import { cv } from "../data/marcus";
import type { SkillKind } from "../data/icv";

interface Props {
  title?: string;
  description?: string;
}

const { title = "Marcus Forte", description = "Marcus Forte - personal site" } = Astro.props;

const skillKinds: SkillKind[] = ["Design", "Technology", "People", "Technique"];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <header>
      <nav>
        <a href="/" class="site-title">Marcus Forte</a>
        <ul>
          <li><a href="/#projects">Projects</a></li>
          <li><a href="/education">Education</a></li>
          <li><a href="/skills">Skills</a></li>
          <li><a href="/#milestones">Additional Milestones</a></li>
          <li><a href="/personal-projects">Personal Projects</a></li>
          <li><a href="/#contact">Contact</a></li>
          <li><button type="button" class="nav-export btn" data-export-pdf>Export PDF</button></li>
        </ul>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <p>&copy; {new Date().getFullYear()} Marcus Forte</p>
    </footer>
  </body>
</html>

<div id="pdf-cv-data" data-json={encodeURIComponent(JSON.stringify({ cv, skillKinds }))} hidden></div>

<script>
  import "../scripts/pdf-export";
</script>
