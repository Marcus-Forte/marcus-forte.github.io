---
import BaseLayout from "../layouts/BaseLayout.astro";
import { cv } from "../data/marcus";
import marcusPhoto from "../marcus.png";
import { textToHtmlBreaks } from "../utils/text";

const skillsById = new Map(cv.skills.map((skill) => [skill.id, skill]));
---

<BaseLayout
  title="Marcus Forte | Software Architect"
  description="Software architect specializing in embedded systems, robotics, and high-tech industrial software."
>
  <section id="hero">
    <div class="hero-content">
      <div class="hero-copy">
        <p class="eyebrow">Eindhoven, Netherlands</p>
        <h1>Marcus Forte</h1>
        <p class="subtitle">Software Architect</p>
        <a href="#projects" class="btn">View Projects</a>
      </div>
      <img src={marcusPhoto.src} alt="Portrait of Marcus Forte" class="hero-photo" />
    </div>
  </section>

  <section id="about">
    <h2>About</h2>
    <p set:html={textToHtmlBreaks(cv.about)} />
  </section>

  <section id="projects">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Professional Experience</p>
        <h2>Projects</h2>
      </div>
      <span class="item-count">{cv.projects.length} projects</span>
    </div>
    <div class="project-list">
      {
        cv.projects.map((project) => (
          <a href={`/projects/${project.id}`} class="project-card-link">
            <article class="card project-card">
              <p class="card-period">{project.period}</p>
              <p class="company-badge">{project.company}</p>
              <div class="project-title-row">
                <h3>{project.title}</h3>
                {project.logo && (
                  <img src={project.logo} alt={`${project.company} logo`} class="project-logo" loading="lazy" />
                )}
              </div>
              <p class="project-role">{project.role}</p>
              <p set:html={textToHtmlBreaks(project.description)} />
              {(project.responsabilities?.length ?? 0) > 0 && (
                <>
                  <p class="project-responsabilities-title">Responsabilities</p>
                  <ul class="project-responsabilities" aria-label="Key responsibilities">
                    {project.responsabilities?.map((item) => (
                      <li>{item}</li>
                    ))}
                  </ul>
                </>
              )}
              <ul class="skill-tags" aria-label="Skills used">
                {project.skills.map((skillId) => {
                  const skill = skillsById.get(skillId);
                  return <li>{skill?.name ?? skillId}</li>;
                })}
              </ul>
              <span class="project-link">View Project Details</span>
            </article>
          </a>
        ))
      }
    </div>
  </section>

  <section id="milestones">
    <p class="eyebrow">Beyond the Work</p>
    <h2>Additional Milestones</h2>
    <ul class="milestone-list">
      {cv.milestones.map((milestone) => <li>{milestone}</li>)}
    </ul>
  </section>

  <section id="contact">
    <h2>Contact</h2>
    <p>Find me on:</p>
    <ul class="contact-links">
      <li>
        <a href="https://github.com/Marcus-Forte" target="_blank" rel="noopener noreferrer">GitHub</a>
      </li>
      <li><a href="mailto:davi2812@hotmail.com">Email</a></li>
      <li>
        <a href="https://www.linkedin.com/in/marcus-forte-4b500a118" target="_blank" rel="noopener noreferrer"
          >LinkedIn</a
        >
      </li>
      <li>
        <a href="https://www.youtube.com/@practicalsoftwaremarcus" target="_blank" rel="noopener noreferrer">YouTube</a>
      </li>
    </ul>
  </section>
</BaseLayout>
