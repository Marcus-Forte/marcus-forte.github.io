---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { cv } from "../../data/marcus";
import { textToHtmlBreaks } from "../../utils/text";

export function getStaticPaths() {
  return cv.personalProjects.map((project) => ({ params: { id: project.id } }));
}

const { id } = Astro.params;
const project = cv.personalProjects.find((entry) => entry.id === id);
const skillsById = new Map(cv.skills.map((skill) => [skill.id, skill]));

const toEmbedUrl = (rawUrl?: string) => {
  if (!rawUrl) return undefined;

  try {
    const url = new URL(rawUrl);
    const host = url.hostname.replace(/^www\./, "");

    if (host === "youtube.com" || host === "m.youtube.com") {
      if (url.pathname.startsWith("/embed/")) {
        return rawUrl;
      }

      const videoId = url.searchParams.get("v");
      if (videoId) {
        return `https://www.youtube.com/embed/${videoId}`;
      }
    }

    if (host === "youtu.be") {
      const videoId = url.pathname.split("/").filter(Boolean)[0];
      if (videoId) {
        return `https://www.youtube.com/embed/${videoId}`;
      }
    }
  } catch {
    return rawUrl;
  }

  return rawUrl;
};

const videoEmbedUrl = toEmbedUrl(project?.videoEmbedUrl);
const gifUrl = project?.gif || project?.gifUrl;

if (!project) {
  throw new Error(`Personal project page not found for id: ${id}`);
}
---

<BaseLayout title={`${project.title} | Personal Project`} description={project.description}>
  <section class="page-intro">
    <p class="eyebrow">Personal Project Detail</p>
    <div class="project-title-row">
      <h1>{project.title}</h1>
      {
        project.logo && (
          <img
            src={project.logo}
            alt={project.company ? `${project.company} logo` : `${project.title} logo`}
            class="project-logo"
            loading="lazy"
          />
        )
      }
    </div>
    {project.role && <p class="project-role">{project.role}</p>}
    {project.company && <p class="company-badge">{project.company}</p>}
    {project.period && <p class="subtitle">{project.period}</p>}
  </section>

  <section class="skills-section">
    <h2>Description</h2>
    <p set:html={textToHtmlBreaks(project.description)} />
    {
      (project.responsabilities?.length ?? 0) > 0 && (
        <>
          <p class="project-responsabilities-title">Responsabilities</p>
          <ul class="project-responsabilities" aria-label="Key responsibilities">
            {project.responsabilities?.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </>
      )
    }
  </section>

  {
    videoEmbedUrl && (
      <section class="skills-section">
        <h2>Video</h2>
        <div class="project-video-wrap">
          <iframe
            src={videoEmbedUrl}
            title={`${project.title} video`}
            loading="lazy"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            referrerpolicy="strict-origin-when-cross-origin"
            allowfullscreen
          />
        </div>
      </section>
    )
  }

  {
    gifUrl && (
      <section class="skills-section">
        <h2>GIF</h2>
        <figure class="project-image-card project-image-clickable">
          <button
            type="button"
            class="image-zoom-trigger"
            data-enlarge-image
            data-image-src={gifUrl}
            data-image-alt={`${project.title} animated preview`}
            aria-label={`Enlarge ${project.title} animated preview`}
          >
            <img src={gifUrl} alt={`${project.title} animated preview`} loading="lazy" />
          </button>
        </figure>
      </section>
    )
  }

  <section class="skills-section">
    <h2>Skills</h2>
    <ul class="skill-tags project-skill-list" aria-label="Project skills">
      {
        project.skills.map((skillId) => {
          const skill = skillsById.get(skillId);
          return <li>{skill?.name ?? skillId}</li>;
        })
      }
    </ul>
  </section>

  {
    (project.images ?? []).length > 0 && (
      <section class="skills-section">
        <h2>Images</h2>
        <div class="project-image-grid">
          {(project.images ?? []).map((imageSrc, index) => (
            <figure class="project-image-card project-image-clickable">
              <button
                type="button"
                class="image-zoom-trigger"
                data-enlarge-image
                data-image-src={imageSrc}
                data-image-alt={`${project.title} image ${index + 1}`}
                aria-label={`Enlarge ${project.title} image ${index + 1}`}
              >
                <img src={imageSrc} alt={`${project.title} image ${index + 1}`} loading="lazy" />
              </button>
            </figure>
          ))}
        </div>
      </section>
    )
  }

  <dialog class="image-lightbox" data-image-dialog>
    <button type="button" class="image-lightbox-close" data-close-image-dialog aria-label="Close enlarged image">
      Close
    </button>
    <img src="" alt="" data-image-dialog-content />
  </dialog>
</BaseLayout>

<script>
  const dialog = document.querySelector("[data-image-dialog]");
  const dialogImage = document.querySelector("[data-image-dialog-content]");
  const triggers = document.querySelectorAll("[data-enlarge-image]");

  if (dialog instanceof HTMLDialogElement && dialogImage instanceof HTMLImageElement) {
    triggers.forEach((trigger) => {
      trigger.addEventListener("click", () => {
        const imageSource = trigger.getAttribute("data-image-src");
        const imageAlt = trigger.getAttribute("data-image-alt") ?? "Enlarged project image";

        if (!imageSource) {
          return;
        }

        dialogImage.src = imageSource;
        dialogImage.alt = imageAlt;
        dialog.showModal();
      });
    });

    dialog.addEventListener("click", (event) => {
      const target = event.target;
      if (!(target instanceof HTMLElement)) {
        return;
      }

      if (target === dialog || target.hasAttribute("data-close-image-dialog")) {
        dialog.close();
      }
    });

    dialog.addEventListener("close", () => {
      dialogImage.src = "";
      dialogImage.alt = "";
    });
  }
</script>
