---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { cv } from "../../data/marcus";
import type { PersonalProject } from "../../data/icv";

const skillsById = new Map(cv.skills.map((skill) => [skill.id, skill]));

const toPreviewImage = (project: PersonalProject<string>) => {
  if ((project.images?.length ?? 0) > 0) {
    return project.images?.[0];
  }

  return project.gif;
};
---

<BaseLayout
  title="Personal Projects | Marcus Forte"
  description="Personal projects by Marcus Forte with skills and optional media."
>
  <section class="page-intro">
    <p class="eyebrow">Independent Work</p>
    <h1>Personal Projects</h1>
    <p class="subtitle">Side initiatives, experiments, and educational projects built outside client engagements.</p>
  </section>

  <section class="skills-section">
    {
      cv.personalProjects.length > 0 ? (
        <div class="project-list">
          {cv.personalProjects.map((project) => {
            const previewImage = toPreviewImage(project);
            return (
              <a href={`/personal-projects/${project.id}`} class="project-card-link">
                <article class="card project-card">
                  <h3>{project.title}</h3>
                  <p>{project.description}</p>
                  {previewImage && (
                    <figure class="project-image-card">
                      <img src={previewImage} alt={`${project.title} preview`} loading="lazy" />
                    </figure>
                  )}
                  <ul class="skill-tags" aria-label={`Skills used in ${project.title}`}>
                    {project.skills.map((skillId) => {
                      const skill = skillsById.get(skillId);
                      return <li>{skill?.name ?? skillId}</li>;
                    })}
                  </ul>
                  <span class="project-link">View Project Details</span>
                </article>
              </a>
            );
          })}
        </div>
      ) : (
        <p class="subtitle">No personal projects added yet.</p>
      )
    }
  </section>
</BaseLayout>
